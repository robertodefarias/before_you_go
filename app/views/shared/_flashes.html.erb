<div class="flash-container">
  <% if notice %>
    <div class="flash-card flash-notice" data-controller="flash" data-action="click->flash#dismiss">
      <div class="flash-icon">✅</div>
      <div class="flash-message"><%= notice %></div>
      <button class="flash-close">&times;</button>
    </div>
  <% end %>

  <% if alert %>
    <div class="flash-card flash-alert" data-controller="flash" data-action="click->flash#dismiss">
      <div class="flash-icon">⚠️</div>
      <div class="flash-message"><%= alert %></div>
      <button class="flash-close">&times;</button>
    </div>
  <% end %>
</div>
