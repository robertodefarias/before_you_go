<div class="search-bar"
     data-controller="search"
     data-search-mapbox-key-value="<%= ENV['MAPBOX_API_KEY'] %>"
     data-action="click@document->search#handleDocumentClick">
  <%= form_with url: places_path, method: :get, local: true, class: "search-form" do |f| %>
    <div class="search-input-wrapper">
      <%= f.text_field :query,
            value: params[:query],
            placeholder: I18n.locale.to_s == "pt-BR" ? "Digite um local ou endereço..." : "Search for a place or address...",
            class: "search-input",
            data: {
              search_target: "input",
              home_hero_map_target: "searchInput",
              action: "input->search#search keydown->search#onKeydown input->home-hero-map#handleInput focus->home-hero-map#handleFocus blur->home-hero-map#handleBlur"
            },
            autocomplete: "off",
            role: "combobox",
            aria: {
              autocomplete: "list",
              controls: "search-suggestions-list",
              expanded: "false",
              label: I18n.locale.to_s == "pt-BR" ? "Buscar local ou endereço" : "Search for place or address"
            } %>

      <%= button_tag type: "submit", class: "search-button", aria: {
            label: I18n.locale.to_s == "pt-BR" ? "Buscar" : "Search"
          } do %>
        <%= image_tag "icone_go_botao.png", alt: "", class: "search-button-icon" %>
        <span class="search-button-text sr-only">
          <%= I18n.locale.to_s == "pt-BR" ? "Buscar" : "Search" %>
        </span>
      <% end %>
    </div>

    <!-- Sugestões em tempo real -->
    <div id="search-suggestions-list" data-search-target="suggestions" class="search-suggestions" role="listbox" aria-live="polite"></div>
  <% end %>
</div>
