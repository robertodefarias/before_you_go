<% portuguese = I18n.locale.to_s == "pt-BR" %>

<% status_class =
     case place.status
     when "positive" then "map-popup-status--positive"
     when "negative" then "map-popup-status--negative"
     else "map-popup-status--neutral"
     end %>

<% badge_text =
     if portuguese
       case place.status
       when "positive" then "Local seguro"
       when "negative" then "Evitar"
       else "Atenção"
       end
     else
       case place.status
       when "positive" then "Safe place"
       when "negative" then "Avoid"
       else "Attention"
       end
     end %>

<% latest_report = place.reports.last %>

<% latest_report_text = latest_report&.translated_description %>

<div class="map-popup-card">
  <div class="map-popup-status <%= status_class %>"></div>

  <div class="map-popup-body">
    <div class="map-popup-header">
      <span class="map-popup-badge"><%= badge_text %></span>
      <h3 class="map-popup-title"><%= place.name %></h3>
    </div>

    <p class="map-popup-text">
      <%= latest_report_text.presence || (portuguese ? "Ainda não há relatos para este local." : "There are no reports for this place yet.") %>
    </p>

    <div class="map-popup-footer">
      <%= link_to(
            portuguese ? "Ver detalhes" : "View details",
            place_path(place),
            class: "map-popup-button"
          ) %>
    </div>
  </div>
</div>
