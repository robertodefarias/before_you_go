<div class="auth-container">
  <div class="auth-shell">
    <section class="auth-aside">
      <span class="auth-eyebrow"><%= t("auth.shared.eyebrow") %></span>
      <h1><%= t("auth.shared.side_title") %></h1>
      <p><%= t("auth.shared.side_text") %></p>

      <div class="auth-benefits">
        <div class="auth-benefit">
          <div class="auth-benefit-mark">1</div>
          <div>
            <strong><%= t("auth.shared.benefit_one_title") %></strong>
            <span><%= t("auth.shared.benefit_one_text") %></span>
          </div>
        </div>

        <div class="auth-benefit">
          <div class="auth-benefit-mark">2</div>
          <div>
            <strong><%= t("auth.shared.benefit_two_title") %></strong>
            <span><%= t("auth.shared.benefit_two_text") %></span>
          </div>
        </div>

        <div class="auth-benefit">
          <div class="auth-benefit-mark">3</div>
          <div>
            <strong><%= t("auth.shared.benefit_three_title") %></strong>
            <span><%= t("auth.shared.benefit_three_text") %></span>
          </div>
        </div>
      </div>
    </section>

    <section class="auth-card">
      <div class="auth-card-header">
        <h2><%= t("auth.signup.title") %></h2>
        <p><%= t("auth.signup.subtitle") %></p>
      </div>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
        <%= f.input :first_name, required: true, autofocus: true,
                    input_html: { class: "form-control", autocomplete: "given-name" } %>

        <%= f.input :email, required: true,
                    input_html: { class: "form-control", autocomplete: "email" } %>

        <%= f.input :password, required: true,
                    hint: (t('devise.registrations.password_placeholder', count: @minimum_password_length) if @minimum_password_length),
                    input_html: { class: "form-control", autocomplete: "new-password" } %>

        <%= f.input :password_confirmation, required: true,
                    input_html: { class: "form-control", autocomplete: "new-password" } %>

        <%= f.button :submit, t("auth.signup.submit"), class: "auth-submit" %>
      <% end %>

      <div class="auth-links">
        <%= render "devise/shared/links" %>
      </div>
    </section>
  </div>
</div>
