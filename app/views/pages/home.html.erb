<div class="home-page">
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          <span>Urban safety insights for nightlife and public places</span>
        </div>

        <h1 class="hero-title">
          Know where you’re going
          <span>before you go</span>
        </h1>

        <p class="hero-subtitle">
          Search for bars, restaurants, clubs and venues. Check community safety reports
          about harassment, violence, prejudice and other incidents before deciding to go.
        </p>

        <div class="hero-search-card">
          <form action="#" method="get" class="hero-search-form">
            <div class="search-input-group">
              <span class="search-icon">📍</span>
              <input
                type="text"
                name="query"
                class="hero-search-input"
                placeholder="Search by place name or address"
              >
              <button type="submit" class="hero-search-button">
                Search
              </button>
            </div>
          </form>

          <p class="search-helper-text">
            Example: “Tokyo Club”, “Paulista Avenue”, “Bar in Pinheiros”
          </p>
        </div>

        <div class="hero-stats">
          <div class="mini-stat">
            <strong>Community-powered</strong>
            <span>Real reports from real people</span>
          </div>

          <div class="mini-stat">
            <strong>Fast decision</strong>
            <span>See the safety status instantly</span>
          </div>

          <div class="mini-stat">
            <strong>Anonymous reporting</strong>
            <span>Safer sharing for sensitive situations</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-info-section">
    <div class="container">
      <div class="section-heading">
        <h2>How it works</h2>
        <p>
          A simple way to help people make safer decisions about where they go.
        </p>
      </div>

      <div class="info-cards-grid">
        <div class="info-card">
          <div class="info-card-icon">🔎</div>
          <h3>Search a place</h3>
          <p>
            Type the name of a venue, bar, restaurant or address and quickly check what people have reported.
          </p>
        </div>

        <div class="info-card">
          <div class="info-card-icon">🛡️</div>
          <h3>Understand the safety status</h3>
          <p>
            View whether the place is currently perceived as positive, negative or neutral based on community reports.
          </p>
        </div>

        <div class="info-card">
          <div class="info-card-icon">✍️</div>
          <h3>Leave your report</h3>
          <p>
            After visiting, contribute with your experience and help others make better and safer choices.
          </p>
        </div>
      </div>
    </div>
  </section>
</div>
