<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Before You Go - Mapa de Segurança" %></title>

    <meta property="og:title" content="<%= content_for(:title) || "Before You Go - Mapa de Segurança" %>">
    <meta property="og:description" content="Mapa comunitário de segurança. Consulte relatos de incidentes em bares e restaurantes antes de sair.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.base_url %>">
    <meta property="og:image" content="<%= request.base_url %>/images/og-cover.png">

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Before You Go">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet">
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/navbar" %>
    <%= render "shared/flashes" %>
    <main>
      <%= yield %>
    </main>
    <footer class="footer">
      <div class="container">
        <div class="row align-items-center footer__top">
          <div class="col-md-4 text-center text-md-start">
            <span class="footer__rights"><%= t("footer.rights") %></span>
          </div>

          <div class="col-md-8 text-center text-md-end">
            <span class="footer__credits">
              <%= t("footer.developed_by") %>
              <%= link_to "Bruno Wallace", "https://github.com/bruno-wallace-nable", target: "_blank", rel: "noopener noreferrer", class: "footer__link" %>,
              <%= link_to "Pedro Abreu", "https://github.com/peedroabreu", target: "_blank", rel: "noopener noreferrer", class: "footer__link" %>
              <%= t("footer.and_connector") %>
              <%= link_to "Roberto de Farias", "https://github.com/robertodefarias", target: "_blank", rel: "noopener noreferrer", class: "footer__link" %>.
            </span>
          </div>
        </div>

        <div class="row footer__bottom">
          <div class="col-12 text-center">
            <hr class="footer__divider">
            <p class="footer__disclaimer">
              <strong><%= t("footer.disclaimer_label") %></strong>
              <%= t("footer.disclaimer_text") %>
            </p>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
